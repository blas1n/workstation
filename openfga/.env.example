# OpenFGA / Postgres environment template.
#
# Copy to openfga/.env (gitignored) and fill in the secrets:
#   cp openfga/.env.example openfga/.env
#   chmod 600 openfga/.env
#   # generate secrets with: openssl rand -hex 32
#
# Loaded by: docker compose -f docker-compose.openfga.yml --env-file openfga/.env

# OpenFGA image version — pin a specific tag. Bump deliberately.
OPENFGA_VERSION=v1.6.2

# Host ports — must not conflict with port-map.md.
OPENFGA_HTTP_PORT=8765
OPENFGA_GRPC_PORT=8766
OPENFGA_PLAY_PORT=3030
OPENFGA_PG_PORT=5440

# Postgres datastore credentials (dedicated DB, not shared with product DBs).
OPENFGA_PG_DB=openfga
OPENFGA_PG_USER=openfga
# REQUIRED: openssl rand -hex 32
OPENFGA_PG_PASSWORD=

# Authentication — preshared API tokens consumed by bsvibe-authz.
# CSV list. Rotate quarterly (Auth_Design.md §10.3).
OPENFGA_AUTHN_METHOD=preshared
# REQUIRED: openssl rand -hex 32 (comma-separated for rotation overlap)
OPENFGA_AUTHN_PRESHARED_KEYS=

# Logging / Playground.
OPENFGA_LOG_LEVEL=info
# Disable in fully locked-down prod. Default exposes only on 127.0.0.1.
OPENFGA_PLAYGROUND_ENABLED=true

# ─── bsvibe-authz client config (these read by P0.4 / products) ───
# Documented here so all four product .env.production files use the same names.

# OPENFGA_API_URL=http://host.docker.internal:8765    # from product containers on the same host
# OPENFGA_STORE_ID=                                   # populated by openfga-bootstrap.sh
# OPENFGA_AUTH_MODEL_ID=                              # populated by openfga-bootstrap.sh
# OPENFGA_AUTH_TOKEN=                                 # one of OPENFGA_AUTHN_PRESHARED_KEYS
