<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.blas1n.bsvibe-demo-gc</string>
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/blasin/Works/_infra/scripts/bsvibe-demo-gc.sh</string>
    </array>
    <!-- Hourly tick (3600s). Runs first 60s after load too via RunAtLoad. -->
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/blasin/Works/_infra/logs/bsvibe-demo-gc.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/blasin/Works/_infra/logs/bsvibe-demo-gc.log</string>
</dict>
</plist>
